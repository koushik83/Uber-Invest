data/changelog/

# Dashboard-cache JSONs (regenerated from data/holdings/ every CI run).
# The deploy job rebuilds them via `python scraper/main.py --export-only`
# right before `npm run build`, so they don't need to live in git.
data/frontend/*.json
frontend/public/data/*.json

